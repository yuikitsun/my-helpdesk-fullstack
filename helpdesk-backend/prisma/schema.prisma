datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  firstName String
  lastName  String
  role      String   @default("employee") // employee | admin | super_admin
  status    String   @default("pending")  // pending | active | rejected
  createdAt DateTime @default(now())
  approvedBy Int?
  approvedAt DateTime?
  devices   Device[]
}

model Device {
  id          String      @id 
  title       String
  type        String   
  status      String   
  cpu         String?
  ram         String?
  location    String?
  notes       String?
  userId      Int?    
  assignedTo  User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  firstName String   
  lastName  String   
  role
  devices   Device[]
}

model Device {
  id          String      @id 
  title       String
  type        String   
  status      String   
  cpu         String?
  ram         String?
  location    String?
  notes       String?
  userId      Int?    
  assignedTo  User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}